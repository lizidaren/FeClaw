# FeClaw 配置模板
# 复制为 .env 并填入实际值
# 首次启动请访问 /setup?token=xxx（控制台打印），完成冷启动向导

# ════════════════════════════════════════════════
# 🔑 安全
# ════════════════════════════════════════════════
JWT_SECRET=                                   # ⚠️ 必填！JWT 签名密钥（任意足够长的随机字符串）
# DEBUG=False                                 # 调试模式（生产请保持关闭，开启会暴露错误详情）

# ════════════════════════════════════════════════
# 🌐 域名部署（仅生产域名部署时需要）
# ════════════════════════════════════════════════
# FECLAW_PUBLIC_URL=feclaw.example.com         # 服务器访问地址（域名或 IP:端口）。纯 IP 部署留空即可
# FECLAW_SUBDOMAIN_ENABLED=false               # Agent 子域名模式（需要域名+DNS 泛解析支持）

# ════════════════════════════════════════════════
# 🗄️ 数据库
# ════════════════════════════════════════════════
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/feclaw  # ⚠️ 必填！MySQL 连接串

# ════════════════════════════════════════════════
# 🤖 LLM 提供商（至少配置一个，否则无法对话）
# ════════════════════════════════════════════════
# 推荐配置 DeepSeek + 千问（廉价且效果好）
DEEPSEEK_API_KEY=                             # DeepSeek（deepseek-v4-flash / deepseek-v4-pro）
QWEN_API_KEY=                                 # 通义千问（qwen 系列 / text-embedding-v4）
ZHIPU_API_KEY=                                # 智谱 AI（glm 系列 / embedding-3）
MIMO_API_KEY=                                 # MiMo（mimo-v2-flash / mimo-v2-pro）
DOUBAO_API_KEY=                               # 豆包 / 火山引擎
KIMI_API_KEY=                                 # Kimi / Moonshot（联网搜索用）

# LLM 模型默认配置（非必填，冷启动向导可交互选择）
# MAIN_TEXT_MODEL=deepseek-v4-flash            # 主文本模型
# MAIN_VISION_MODEL=qwen3.6-35b-a3b           # 主视觉模型
# MAIN_EMBEDDING_MODEL=text-embedding-v4      # 主嵌入模型（可用 embedding-3）
# DEFAULT_SEARCH_ENGINE=qwen                  # 默认搜索后端（qwen/glm/kimi）

# ════════════════════════════════════════════════
# ☁️ 对象存储（可选项）
# ════════════════════════════════════════════════
# STORAGE_MODE=auto                           # 存储模式：local（本地）/ cos / auto
# LOCAL_STORAGE_ROOT=./feclaw-storage         # 本地存储根目录
# VECTOR_STORAGE_BACKEND=numpy                # 向量存储后端：numpy / cos / sqlite
# STORAGE_PREFIX=feclaw/                      # 存储前缀，隔离多实例

# 腾讯云 COS（选择 cos 模式时必填）
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=
# TENCENT_COS_BUCKET=
# TENCENT_COS_APPID=
# TENCENT_COS_REGION=ap-guangzhou

# ════════════════════════════════════════════════
# 📦 Redis（可选，用于缓存/会话/性能追踪）
# ════════════════════════════════════════════════
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# ════════════════════════════════════════════════
# 🔐 OAuth / OIDC（可选，默认使用本地注册/登录）
# ════════════════════════════════════════════════
# 配置后可在「管理后台 → 配置 → OAuth / SSO」编辑
# OAUTH_ENABLED=true
# OAUTH_PROVIDER_NAME=OAuth/OIDC 认证服务
# OAUTH_PROVIDER_URL=https://your-idp.example.com
# OAUTH_CLIENT_ID=feclaw
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URI=https://feclaw.example.com/api/oauth/callback

# ════════════════════════════════════════════════
# ⚙️ 高级配置（通常不需要修改）
# ════════════════════════════════════════════════
# HOST=0.0.0.0                                # 监听地址
# PORT=8080                                    # 监听端口
# LOG_LEVEL=INFO                               # 日志级别（DEBUG/INFO/WARNING/ERROR）
# COOKIE_SECURE=false                          # Cookie Secure 标记（HTTPS 开启）
# JWT_EXPIRE_HOURS=24                          # JWT 过期时间
# CACHE_TTL=300                                # 缓存 TTL（秒）
# DESKTOP_ENABLED=false                        # 桌面端 API
# WECHAT_ILINK_API_KEY=                        # 微信 iLink API Key
# MINERU_TOKEN=                                # MinerU 文档解析 Token
# MINIMAX_API_KEY=                             # MiniMax（TTS 语音合成）
# FECLAW_VENV_PATH=./venv                      # 沙箱运行环境路径
# FUSE_MOUNT_DIR=./feclaw-fuse                 # FUSE 挂载目录
# FUSE_ENABLED=false                           # FUSE 文件系统
# SANDBOX_MAX_RUNTIME_HOURS=1                  # 沙箱最大运行时间
