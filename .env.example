# FeClaw 配置模板
# 复制为 .env 并填入实际值

# === 必填 ===
JWT_SECRET=                                   # JWT 签名密钥，任意长字符串

# === 域名（用于 OAuth 回调等，部署时必填） ===
# FECLAW_DOMAIN=feclaw.example.com              # FeClaw 主域名

# === OAuth / OIDC（可选，默认使用本地注册/登录） ===
# 如需 SSO，配置以下项：
# OAUTH_PROVIDER_URL=https://your-idp.example.com
# OAUTH_CLIENT_ID=feclaw
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URI=https://feclaw.example.com/api/oauth/callback
# 端点默认从 OAUTH_PROVIDER_URL 推导 OIDC 标准路径，
# 也可显式覆盖（例如 FirstEntrancePlatform 使用 /oauth/ 前缀）：
# OAUTH_AUTHORIZE_URL=https://your-idp.example.com/oauth/authorize
# OAUTH_TOKEN_URL=https://your-idp.example.com/oauth/token
# OAUTH_USERINFO_URL=https://your-idp.example.com/oauth/userinfo
# OAUTH_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json

# === LLM 提供商（至少填一个） ===
ZHIPU_API_KEY=                                # 智谱 AI（glm 系列、embedding-3）
DEEPSEEK_API_KEY=                             # DeepSeek
DOUBAO_API_KEY=                               # 豆包 / 火山引擎
QWEN_API_KEY=                                 # 通义千问（qwen 系列、text-embedding-v4）
MIMO_API_KEY=                                 # MiMo (mimo-v2-flash / mimo-v2-pro)

# === 主模型配置 ===
# MAIN_TEXT_MODEL=deepseek-v4-flash            # 主文本模型（默认 deepseek-v4-flash）
# MAIN_VISION_MODEL=qwen3.6-35b-a3b           # 主视觉模型（默认 qwen3.6-35b-a3b）
# MAIN_EMBEDDING_MODEL=text-embedding-v4      # 主嵌入模型（默认 text-embedding-v4，可选 embedding-3）

# === 联网搜索（三级架构，至少填一个） ===
TENCENT_SEARCH_API_KEY=                       # L1 极简搜索（腾讯云搜狗）
KIMI_API_KEY=                                 # L2 高级搜索（Moonshot Kimi）
BAIDU_SEARCH_API_KEY=                         # L3 研究级搜索（百度千帆）

# === 腾讯云 COS（图片/文件存储） ===
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_APPID=

# === Redis（可选，用于缓存/会话持久化） ===
REDIS_PASSWORD=

# === 微信 iLink（可选） ===
WECHAT_ILINK_BASE_URL=
WECHAT_ILINK_API_KEY=

# === MinerU 文档解析（可选） ===
MINERU_TOKEN=

# === 数据库（默认 SQLite，可选 MySQL） ===
# 默认使用 SQLite（data/feclaw.db），以下为 MySQL 配置
# USE_MYSQL=true
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/feclaw
